{
  "name": "cfitsio",
  "version": "4.6.4",
  "port-version": 1,
  "description": "Library of C and Fortran subroutines for reading and writing data files in FITS (Flexible Image Transport System) data format",
  "homepage": "https://heasarc.gsfc.nasa.gov/fitsio/",
  "dependencies": [
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    },
    "zlib"
  ],
  "features": {
    "bzip2": {
      "description": "Bzip2 compression",
      "dependencies": [
        "bzip2"
      ]
    },
    "curl": {
      "description": "Network file access",
      "dependencies": [
        "curl"
      ]
    },
    "pthreads": {
      "description": "Thread-safe build (using pthreads)",
      "dependencies": [
        {
          "name": "pthreads4w",
          "platform": "windows & !mingw"
        }
      ]
    },
    "tools": {
      "description": "Build utility programs"
    }
  }
}
