{
  "name": "behaviortree-cpp",
  "version": "4.9.1",
  "port-version": 2,
  "description": "Behavior Trees Library in C++.",
  "homepage": "https://www.behaviortree.dev",
  "license": "MIT AND (MIT-0 OR Unlicense)",
  "supports": "!uwp",
  "dependencies": [
    "flatbuffers",
    "minitrace",
    "tinyxml2",
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "features": {
    "groot": {
      "description": "Enable the Groot2 publisher interface.",
      "dependencies": [
        "cppzmq"
      ]
    },
    "sqlite": {
      "description": "Enable SQLite logging.",
      "dependencies": [
        "sqlite3"
      ]
    }
  }
}
